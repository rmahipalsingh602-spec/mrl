{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MRL",
  "scopeName": "source.mrl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#function-definitions" },
    { "include": "#function-calls" },
    { "include": "#keywords" },
    { "include": "#ui-keywords" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mrl",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mrl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mrl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.mrl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mrl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "name": "meta.function.definition.mrl",
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.mrl"
            },
            "2": {
              "name": "entity.name.function.mrl"
            }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function.call.mrl",
          "match": "\\b(call)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "keyword.control.call.mrl"
            },
            "2": {
              "name": "variable.function.mrl"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mrl",
          "match": "\\b(mrl|bolo|rakho|agar|warna|jab|tak|gino|se|kadam|khatam|function|call|import|install|ai|sach|jhooth|aur|ya|nahi)\\b"
        }
      ]
    },
    "ui-keywords": {
      "patterns": [
        {
          "name": "support.type.mrl",
          "match": "\\b(ui|window|button|text|end)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.mrl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.mrl",
          "match": "==|!=|<=|>=|=|\\+|-|\\*|/|<|>"
        }
      ]
    }
  }
}
