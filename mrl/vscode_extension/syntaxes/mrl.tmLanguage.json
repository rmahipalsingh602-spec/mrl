{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MRL",
  "scopeName": "source.mrl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mrl",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mrl",
          "match": "\\b(mrl|bolo|rakho|agar|warna|jab|tak|gino|se|kadam|khatam|function|call|import|install|ai|sach|jhooth|aur|ya|nahi|ui|window|button|text|end)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mrl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mrl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.mrl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mrl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.mrl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.mrl",
          "match": "==|!=|<=|>=|=|\\+|-|\\*|/|<|>"
        }
      ]
    }
  }
}
